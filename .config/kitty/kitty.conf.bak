# -------------------------
# Shell
# -------------------------
shell pwsh -NoLogo

# -------------------------
# Window
# -------------------------
window_decorations none
confirm_os_window_close 0
window_padding_width 10
background_opacity 0.65
dynamic_background_opacity yes
enable_blur yes
title Kitty
class_name kitty
instance_name Kitty

# -------------------------
# Behaviour
# -------------------------
clipboard_control write-clipboard write-primary no-append
copy_on_select no

# -------------------------
# Font
# -------------------------
font_family FiraCode Nerd Font
bold_font FiraCode Nerd Font Bold
italic_font FiraCode Nerd Font Italic
font_size 11.0

# -------------------------
# Cursor
# -------------------------
cursor_shape block
cursor_blink_interval 0.75
cursor_stop_blinking_after 0

# -------------------------
# Scrolling
# -------------------------
scrollback_lines 10000
wheel_scroll_multiplier 3.0

# -------------------------
# Colors
# -------------------------
foreground #e8d5c4
cursor #ff8c42
cursor_text_color #1a1410
selection_foreground #1a1410
selection_background #ff8c42

# Normal colors
color0  #b8b8b8
color1  #ff6a3d
color2  #95d5b2
color3  #ffb84d
color4  #a8c5e6
color5  #e6a8c5
color6  #8ecfd4
color7  #e8e8e8

# Bright colors
color8  #d4d4d4
color9  #ff8547
color10 #b8e6cf
color11 #ffc966
color12 #c5daf5
color13 #f5c5da
color14 #ade6eb
color15 #f5f5f5

# -------------------------
# Key Bindings
# -------------------------
map ctrl+c copy_to_clipboard
map ctrl+v paste_from_clipboard
map ctrl+shift+c send_text all \x03
map ctrl+shift+v send_text all \x16
map ctrl+plus change_font_size all +1.0
map ctrl+minus change_font_size all -1.0
map ctrl+0 change_font_size all 0

# -------------------------
# Mouse Behavior
# -------------------------
mouse_hide_wait 3.0
mouse_map right press ungrabbed combine : copy_to_clipboard : clear_selection : paste_from_clipboard