XDG_LIB_DIR="$HOME/.local/lib"
XDG_MEDIA_DIR="$HOME/Media"
XDG_MUSIC_DIR="$HOME/Music"
XDG_PASSWORDSTORE_DIR="$HOME/.password-store"
XDG_PICTURES_DIR="$HOME/Pictures"
XDG_PRIVATE_DIR="$HOME/.data"
XDG_SSH_DIR="$HOME/.ssh"
XDG_STATE_DIR="$HOME/.local/state"
