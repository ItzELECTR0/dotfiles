XDG_CACHE_DIR="$HOME/.cache"
XDG_CONFIG_DIR="$HOME/.config"
XDG_DATA_DIR="$HOME/.local/share"
XDG_DESKTOP_DIR="$HOME/Desktop"
XDG_DEVELOPMENT_DIR="$HOME/Development"
XDG_DOCUMENTS_DIR="$HOME/Documents"
